{
  "name": "@adonis/agents",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "scrape:once": "tsx src/scripts/scrape-once.ts",
    "digest:preview": "tsx src/scripts/digest-preview.ts",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@adonis/db": "workspace:*",
    "@adonis/shared": "workspace:*",
    "@anthropic-ai/sdk": "^0.30.1",
    "cheerio": "^1.0.0",
    "node-cron": "^3.0.3",
    "playwright": "^1.48.0",
    "resend": "^4.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
